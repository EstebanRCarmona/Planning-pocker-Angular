{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && npm run server:install",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "FRONTEND_URL": "@frontend_url",
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "functions": {
    "server/dist/index.js": {
      "runtime": "@vercel/node@2.15.8",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/dist/index.js"
    },
    {
      "src": "/socket.io(.*)",
      "dest": "/server/dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server/dist/index.js"
    }
  ]
}
