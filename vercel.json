{
  "version": 2,
  "buildCommand": "npm --prefix server install && ng build && npm --prefix server run build",
  "functions": {
    "server/dist/index.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/dist/index.js"
    },
    {
      "src": "/socket.io(.*)",
      "dest": "server/dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "server/dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
